{
  "name": "@pms/db",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": "test",
    "testRegex": ".spec.ts$",
    "testTimeout": 20000
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
