# Postgres (matches docker-compose.yml — mapped to host port 5433, not the
# default 5432, because this machine already has a native Postgres service
# bound to 5432)
#
# `pms` (POSTGRES_USER in docker-compose.yml) is a Postgres SUPERUSER, and
# superusers bypass Row-Level Security unconditionally. It must only be used
# for running migrations/seeds (packages/db/.env), never for the running
# application. Runtime app connections (apps/api/.env) must use the
# restricted `pms_app` role instead (created by migration
# 20260702171808_app_role_privilege_separation), or every RLS policy in this
# schema is silently inert.
DATABASE_URL="postgresql://pms_app:pms_app_dev_password@localhost:5433/pms?schema=public"
# Non-pooled direct connection, used by Prisma migrate (same as DATABASE_URL until a pooler is introduced)
DIRECT_URL="postgresql://pms_app:pms_app_dev_password@localhost:5433/pms?schema=public"
# Superuser connection, used ONLY by test fixture setup (seeding rows across
# multiple tenants, which RLS blocks the app role from doing) and by
# tenant-provisioning code (see tenants.service.ts, slice 3+). Never used on
# a request path.
MIGRATION_DATABASE_URL="postgresql://pms:pms_dev_password@localhost:5433/pms?schema=public"
# Narrow, SELECT-only, BYPASSRLS role used ONLY for pre-auth bootstrap
# lookups (resolve tenant by slug, resolve a magic-link token by hash) where
# the tenant isn't known yet, so the normal RLS-scoped path can't serve the
# query at all. See migration 20260702173133_auth_bootstrap_role.
AUTH_BOOTSTRAP_DATABASE_URL="postgresql://pms_authbootstrap:pms_authbootstrap_dev_password@localhost:5433/pms?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Auth providers: stub (dev, no live OAuth/email) | google | microsoft (sso); stub | ses (magic-link)
AUTH_SSO_PROVIDER="stub"
AUTH_MAGIC_LINK_PROVIDER="stub"

# API
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000"
